---
import { Image } from 'astro:assets';

interface Photo {
  src: string;
  alt: string;
  width: number;
  height: number;
  layout: 'full' | 'half';
}

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/collections/**/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

function resolveImage(src: string): ImageMetadata {
  const key = Object.keys(allImages).find((k) => k.includes(src));
  if (!key) throw new Error(`Image not found: ${src}`);
  return allImages[key].default;
}
---

<div class="photo-grid" id="gallery">
  {photos.map((photo) => {
    const resolved = resolveImage(photo.src);
    return (
      <a
        href={resolved.src}
        data-pswp-width={photo.width}
        data-pswp-height={photo.height}
        target="_blank"
        class="photo-grid__item"
      >
        <Image
          src={resolved}
          alt={photo.alt}
          widths={[200, 350, 500]}
          sizes="(max-width: 640px) 33vw, (max-width: 1024px) 20vw, 14vw"
          loading="lazy"
        />
      </a>
    );
  })}
</div>

<style>
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    padding: 0 32px;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .photo-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .photo-grid {
      grid-template-columns: repeat(7, 1fr);
    }
  }

  .photo-grid__item {
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-bg-raised);
  }

  .photo-grid__item :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease, opacity 0.4s ease;
  }

  .photo-grid__item:hover :global(img) {
    transform: scale(1.05);
  }
</style>
