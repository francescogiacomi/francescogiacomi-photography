---
interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
---

<header class:list={['header', { 'header--transparent': transparent }]} id="site-header">
  <div class="header__inner">
    <a href="/" class="header__logo">francescogiacomi</a>
    <a href="https://www.instagram.com/fncgcm/" target="_blank" rel="noopener noreferrer" class="header__instagram" aria-label="Instagram">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="5" />
        <circle cx="12" cy="12" r="5" />
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
      </svg>
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;

  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const current = window.scrollY;
    if (current > 100) {
      header.classList.toggle('header--hidden', current > lastScroll);
    } else {
      header.classList.remove('header--hidden');
    }
    lastScroll = current;
  }, { passive: true });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
    transition: transform 0.35s ease, background var(--transition);
  }

  .header--hidden {
    transform: translateY(-100%);
  }

  .header--transparent {
    position: fixed;
    width: 100%;
    background: transparent;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-md) 32px;
  }

  .header__logo {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 1.25rem;
    letter-spacing: 0.02em;
    color: var(--color-text);
    transition: opacity var(--transition);
  }

  .header__logo:hover {
    opacity: 0.7;
  }

  .header--transparent .header__logo,
  .header--transparent .header__instagram {
    color: #fff;
  }

  .header__instagram {
    color: var(--color-text);
    transition: opacity var(--transition);
    display: flex;
    align-items: center;
  }

  .header__instagram:hover {
    opacity: 0.7;
  }
</style>
