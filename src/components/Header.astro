---
interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class:list={['header', { 'header--transparent': transparent }]}>
  <div class="header__inner">
    <a href="/" class="header__logo">francescogiacomi</a>
    <nav class="header__nav">
      <a href="/collections" class:list={{ active: currentPath.startsWith('/collections') }}>Collections</a>
      <a href="/about" class:list={{ active: currentPath === '/about' }}>About</a>
      <a href="/contact" class:list={{ active: currentPath === '/contact' }}>Contact</a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
    transition: background var(--transition);
  }

  .header--transparent {
    position: fixed;
    width: 100%;
    background: transparent;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-md) 32px;
  }

  .header__logo {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 1rem;
    letter-spacing: 0.02em;
    transition: opacity var(--transition);
  }

  .header__logo:hover {
    opacity: 0.7;
  }

  .header--transparent .header__logo,
  .header--transparent .header__nav a {
    color: #fff;
  }

  .header__nav {
    display: flex;
    gap: var(--spacing-lg);
  }

  .header__nav a {
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    transition: opacity var(--transition);
  }

  .header__nav a:hover,
  .header__nav a.active {
    opacity: 0.7;
  }
</style>
