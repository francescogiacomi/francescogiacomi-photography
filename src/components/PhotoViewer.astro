---
import { Image } from 'astro:assets';

interface PhotoItem {
  src: string;
  caption?: string;
}

interface Props {
  photos: PhotoItem[];
  /** Optional project info shown on hover (desktop) / at top of feed (mobile). Paragraphs separated by blank lines. */
  info?: string;
}

const { photos, info } = Astro.props;
const infoParagraphs = info
  ? info.split(/\n{2,}/).map((p) => p.trim()).filter(Boolean)
  : [];
const hasInfo = infoParagraphs.length > 0;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/collections/**/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

function resolveImage(src: string): ImageMetadata {
  const key = Object.keys(allImages).find((k) => k.includes(src));
  if (!key) throw new Error(`Image not found: ${src}`);
  return allImages[key].default;
}
---

<section class="viewer">
  <!-- Desktop: top bar -->
  <div class="viewer__top">
    <div class="viewer__nav" id="viewer-nav">
      <button class="viewer__btn" id="btn-prev">Previous</button>
      <span class="viewer__sep">/</span>
      <button class="viewer__btn" id="btn-next">Next</button>
      <span class="viewer__count" id="viewer-count">(1 of {photos.length})</span>
      {hasInfo && <button class="viewer__info-trigger" id="btn-info">info</button>}
    </div>
    <button class="viewer__mode-toggle" id="btn-mode" aria-label="Toggle view">
      <svg class="icon-grid" width="18" height="18" viewBox="0 0 18 18" fill="currentColor">
        <rect x="0" y="0" width="4" height="4" rx="0.5"/><rect x="7" y="0" width="4" height="4" rx="0.5"/><rect x="14" y="0" width="4" height="4" rx="0.5"/>
        <rect x="0" y="7" width="4" height="4" rx="0.5"/><rect x="7" y="7" width="4" height="4" rx="0.5"/><rect x="14" y="7" width="4" height="4" rx="0.5"/>
        <rect x="0" y="14" width="4" height="4" rx="0.5"/><rect x="7" y="14" width="4" height="4" rx="0.5"/><rect x="14" y="14" width="4" height="4" rx="0.5"/>
      </svg>
      <svg class="icon-single" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" style="display:none;">
        <rect x="1" y="1" width="16" height="12" rx="1"/><line x1="1" y1="16" x2="12" y2="16"/>
      </svg>
    </button>
  </div>

  <!-- Desktop: stage (single photo) + info panel overlay -->
  <div class="viewer__body">
    <div class="viewer__stage" id="viewer-stage">
      {photos.map((photo, i) => {
        const resolved = resolveImage(photo.src);
        return (
          <div class={`viewer__slide ${i === 0 ? 'is-active' : ''}`} data-index={i}>
            <Image
              src={resolved}
              alt={photo.caption ?? ''}
              widths={[800, 1200, 1800]}
              sizes="(max-width: 768px) 100vw, 70vw"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>
        );
      })}
    </div>

    {hasInfo && (
      <div class="viewer__info" id="viewer-info">
        {infoParagraphs.map((p) => <p>{p}</p>)}
      </div>
    )}
  </div>

  <p class="viewer__caption" id="viewer-caption">{photos[0].caption ?? ''}</p>

  <!-- Desktop: grid view -->
  <div class="grid-view" id="grid-view">
    {photos.map((photo, i) => {
      const resolved = resolveImage(photo.src);
      return (
        <button class="grid-view__item" data-goto={i}>
          <Image
            src={resolved}
            alt={photo.caption ?? ''}
            widths={[200, 350]}
            sizes="20vw"
            loading="lazy"
          />
        </button>
      );
    })}
  </div>

  <!-- Mobile: scrolling feed -->
  <div class="mobile-feed" id="mobile-feed">
    {hasInfo && (
      <div class="mobile-feed__info">
        {infoParagraphs.map((p) => <p>{p}</p>)}
      </div>
    )}
    {photos.map((photo) => {
      const resolved = resolveImage(photo.src);
      return (
        <figure class="mobile-feed__item">
          <Image
            src={resolved}
            alt={photo.caption ?? ''}
            widths={[600, 900, 1200]}
            sizes="100vw"
            loading="lazy"
          />
          {photo.caption && <figcaption>{photo.caption}</figcaption>}
        </figure>
      );
    })}
  </div>
</section>

<script is:inline define:vars={{ captions: photos.map((p) => p.caption ?? ''), total: photos.length }}>
  let current = 0;
  let gridOpen = false;

  const slides = document.querySelectorAll('.viewer__slide');
  const captionEl = document.getElementById('viewer-caption');
  const countEl = document.getElementById('viewer-count');
  const gridView = document.getElementById('grid-view');
  const viewerStage = document.getElementById('viewer-stage');
  const viewerNav = document.getElementById('viewer-nav');
  const iconGrid = document.querySelector('.icon-grid');
  const iconSingle = document.querySelector('.icon-single');
  const viewerSection = document.querySelector('.viewer');
  const infoTrigger = document.getElementById('btn-info');

  function goTo(index) {
    slides.forEach((s) => s.classList.remove('is-active'));
    slides[index].classList.add('is-active');
    captionEl.textContent = captions[index];
    countEl.textContent = '(' + (index + 1) + ' of ' + total + ')';
    current = index;
    closeInfo();
  }

  document.getElementById('btn-prev').addEventListener('click', () => {
    goTo(current > 0 ? current - 1 : total - 1);
  });

  document.getElementById('btn-next').addEventListener('click', () => {
    goTo(current < total - 1 ? current + 1 : 0);
  });

  // Click the photo to advance to the next one
  viewerStage.addEventListener('click', () => {
    if (!gridOpen) goTo(current < total - 1 ? current + 1 : 0);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') goTo(current > 0 ? current - 1 : total - 1);
    if (e.key === 'ArrowRight') goTo(current < total - 1 ? current + 1 : 0);
    if (e.key === 'Escape' && gridOpen) toggleGrid();
  });

  function toggleGrid() {
    gridOpen = !gridOpen;
    if (gridOpen) closeInfo();
    gridView.classList.toggle('is-open', gridOpen);
    viewerSection.classList.toggle('is-grid', gridOpen);
    iconGrid.style.display = gridOpen ? 'none' : '';
    iconSingle.style.display = gridOpen ? '' : 'none';
  }

  document.getElementById('btn-mode').addEventListener('click', toggleGrid);

  gridView.querySelectorAll('.grid-view__item').forEach((btn) => {
    btn.addEventListener('click', () => {
      goTo(parseInt(btn.dataset.goto));
      if (gridOpen) toggleGrid();
    });
  });

  // Info hover (desktop): show text in place of the photo
  function openInfo() {
    if (!gridOpen) viewerSection.classList.add('is-info');
  }
  function closeInfo() {
    viewerSection.classList.remove('is-info');
  }

  if (infoTrigger) {
    infoTrigger.addEventListener('mouseenter', openInfo);
    infoTrigger.addEventListener('mouseleave', closeInfo);
  }

  // Lazy image fade-in
  document.querySelectorAll('img[loading="lazy"]').forEach((img) => {
    if (img.complete) {
      img.classList.add('is-loaded');
    } else {
      img.addEventListener('load', () => img.classList.add('is-loaded'));
    }
  });
</script>

<style>
  .viewer {
    padding: 48px 72px 56px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .viewer__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .viewer__nav {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .viewer__btn {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition);
  }

  .viewer__btn:hover { color: var(--color-text); }

  .viewer__sep,
  .viewer__count {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .viewer__count { margin-left: 8px; }

  .viewer__info-trigger {
    margin-left: 20px;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition);
  }

  .viewer__info-trigger:hover { color: var(--color-accent); }

  .viewer__mode-toggle {
    color: var(--color-text-muted);
    transition: color var(--transition);
    padding: 4px;
    margin-left: auto;
  }

  .viewer__mode-toggle:hover { color: var(--color-text); }

  /* Stage / info share the same central area */
  .viewer__body {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .viewer__stage {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .viewer__slide {
    display: none;
    width: 100%;
    max-width: 900px;
  }

  .viewer__slide.is-active { display: block; }

  .viewer__slide :global(img) {
    width: 100%;
    height: auto;
    max-height: 75vh;
    object-fit: contain;
  }

  .viewer__info {
    display: none;
    max-width: 640px;
    margin: 0 auto;
  }

  .viewer__info p {
    font-size: 0.9375rem;
    line-height: 1.85;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .viewer__info p:last-child { margin-bottom: 0; }

  /* Info hover state: hide photo, show text */
  .viewer.is-info .viewer__stage { display: none; }
  .viewer.is-info .viewer__info { display: block; }
  .viewer.is-info .viewer__caption { visibility: hidden; }

  .viewer__caption {
    margin-top: 20px;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* Grid view */
  .grid-view {
    display: none;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }

  .grid-view.is-open {
    display: grid;
    flex: 1;
    align-content: start;
  }

  /* When grid is open, hide the single-photo body + caption */
  .viewer.is-grid .viewer__body,
  .viewer.is-grid .viewer__caption,
  .viewer.is-grid .viewer__nav {
    display: none;
  }

  .grid-view__item {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    padding: 0;
    background: var(--color-bg-raised);
  }

  .grid-view__item :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .grid-view__item:hover :global(img) { transform: scale(1.03); }

  /* Mobile feed */
  .mobile-feed { display: none; }

  .mobile-feed__info {
    padding: 4px 0 28px;
  }

  .mobile-feed__info p {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .mobile-feed__info p:last-child { margin-bottom: 0; }

  .mobile-feed__item {
    margin-bottom: 8px;
  }

  .mobile-feed__item :global(img) {
    width: 100%;
    height: auto;
  }

  .mobile-feed__item figcaption {
    padding: 12px 0 24px;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .viewer {
      padding: 0;
      min-height: auto;
    }

    .viewer__top { display: none; }
    .viewer__body { display: none !important; }
    .viewer__caption { display: none !important; }
    .grid-view { display: none !important; }

    .mobile-feed {
      display: block;
      padding: 0 20px;
    }
  }
</style>
