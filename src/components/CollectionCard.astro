---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  slug: string;
  year: number;
  cover: ImageMetadata;
}

const { title, slug, year, cover } = Astro.props;
---

<a href={`/collections/${slug}`} class="card">
  <div class="card__image">
    <Image
      src={cover}
      alt={title}
      widths={[300, 450, 600]}
      sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
      loading="lazy"
    />
  </div>
  <h3 class="card__title">{title}</h3>
  <span class="card__year">{year}</span>
</a>

<style>
  .card {
    display: block;
  }

  .card__image {
    overflow: hidden;
    aspect-ratio: 3 / 2;
    background: var(--color-bg-raised);
  }

  .card__image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .card:hover .card__image :global(img) {
    transform: scale(1.03);
  }

  .card__title {
    margin-top: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .card__year {
    display: block;
    margin-top: 0.15rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
</style>
