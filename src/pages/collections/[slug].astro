---
import GalleryLayout from '../../layouts/GalleryLayout.astro';
import PhotoViewer from '../../components/PhotoViewer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allCollections = await getCollection('collections');
  const sorted = allCollections.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;

const photos = entry.data.photos.map((p) => ({
  src: p.src,
  caption: p.alt && p.alt.length > 0 ? p.alt : `${entry.data.location}, ${entry.data.year}`,
}));

const info = entry.body ?? entry.data.description;
---

<GalleryLayout
  title={`${entry.data.title} | Francesco Giacomi`}
  description={entry.data.description}
  activeNav={entry.data.slug}
>
  <PhotoViewer photos={photos} info={info} />
</GalleryLayout>
