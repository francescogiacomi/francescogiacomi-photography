---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero.jpg';
---

<BaseLayout
  title="Francesco Giacomi | Photography"
  description="Landscape and travel photography by Francesco Giacomi."
  transparentHeader={true}
>
  <section class="hero">
    <div class="hero__image">
      <Image
        src={heroImage}
        alt="Landscape photography by Francesco Giacomi"
        widths={[800, 1200, 1800, 2400]}
        sizes="100vw"
        loading="eager"
      />
    </div>
    <a href="#intro" class="hero__scroll" aria-label="Scroll down">
      <svg width="20" height="12" viewBox="0 0 20 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="1 1 10 10 19 1"></polyline>
      </svg>
      <svg width="20" height="12" viewBox="0 0 20 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="1 1 10 10 19 1"></polyline>
      </svg>
    </a>
  </section>

  <section class="intro" id="intro">
    <div class="container">
      <p>Photographs born from summer travels. Stories told through landscapes, light, and the quiet moments in between.</p>
      <a href="/collections" class="intro__link">View Collections &rarr;</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
  }

  .hero__image {
    position: absolute;
    inset: 0;
  }

  .hero__image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__scroll {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    color: #fff;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    opacity: 0.8;
    transition: opacity var(--transition);
  }

  .hero__scroll:hover {
    opacity: 1;
  }

  .hero__scroll svg:first-child {
    animation: scrollDown 2s ease-in-out infinite;
  }

  .hero__scroll svg:last-child {
    animation: scrollDown 2s ease-in-out infinite 0.3s;
  }

  @keyframes scrollDown {
    0% { opacity: 0; transform: translateY(-6px); }
    50% { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(6px); }
  }

  .intro {
    padding: var(--spacing-2xl) 0;
    text-align: center;
  }

  .intro p {
    font-family: var(--font-sans);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 700px;
    margin: 0 auto;
  }

  .intro__link {
    display: inline-block;
    margin-top: var(--spacing-lg);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-text);
    padding-bottom: 2px;
    transition: opacity var(--transition);
  }

  .intro__link:hover {
    opacity: 0.6;
  }
</style>
