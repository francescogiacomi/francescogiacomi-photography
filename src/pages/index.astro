---
import '@fontsource/geist-sans/400.css';
import '@fontsource/geist-sans/500.css';
import '@fontsource/geist-sans/600.css';
import '@fontsource/geist-sans/700.css';
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const allCollections = await getCollection('collections');
const sorted = allCollections.sort((a, b) => a.data.order - b.data.order);

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/collections/**/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

function resolveImage(src: string): ImageMetadata {
  const key = Object.keys(allImages).find((k) => k.includes(src));
  if (!key) throw new Error(`Image not found: ${src}`);
  return allImages[key].default;
}

const selectedPhotos = [
  { src: 'peru01/_PXP7086.jpg', caption: 'Perù, 2024' },
  { src: 'peru01/_PXP6623.jpg', caption: 'Perù, 2024' },
  { src: 'peru01/_PXP6798.jpg', caption: 'Perù, 2024' },
  { src: 'peru01/_PXP7308.jpg', caption: 'Bolivia, 2024' },
  { src: 'peru01/_PXP7095.jpg', caption: 'Perù, 2024' },
  { src: 'peru01/_PXP7632.jpg', caption: 'Cile, 2024' },
  { src: 'peru01/_PXP7145.jpg', caption: 'Bolivia, 2024' },
  { src: 'peru01/_PXP7360.jpg', caption: 'Cile, 2024' },
  { src: 'peru01/_PXP6437.jpg', caption: 'Perù, 2024' },
  { src: 'peru01/_PXP7159.jpg', caption: 'Perù, 2024' },
  { src: 'peru01/_PXP6768.jpg', caption: 'Perù, 2024' },
  { src: 'peru01/_PXP7866.jpg', caption: 'Perù, 2024' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title="Francesco Giacomi | Photography"
      description="Travel and documentary photography by Francesco Giacomi."
    />
  </head>
  <body>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar__top">
        <a href="/" class="sidebar__name">
          <span>Francesco</span>
          <span>Giacomi</span>
        </a>

        <nav class="sidebar__nav">
          <a href="#" class="nav-link is-active" data-section="selected">Selected Moments</a>
          <div class="nav-group">
            <button class="nav-link nav-link--parent" data-toggle="projects">Projects <span class="nav-arrow">▸</span></button>
            <div class="nav-sub" id="nav-projects">
              {sorted.map((entry) => (
                <a href={`/collections/${entry.data.slug}`} class="nav-sub__link">{entry.data.title}</a>
              ))}
            </div>
          </div>
          <a href="#" class="nav-link" data-section="bio">Bio</a>
        </nav>
      </div>

      <div class="sidebar__bottom">
        <div class="sidebar__social">
          <a href="https://www.instagram.com/fncgcm/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/francescogiacomi/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
        <span class="sidebar__copy">&copy; All rights reserved</span>
      </div>
    </aside>

    <!-- Mobile header -->
    <header class="mobile-header" id="mobile-header">
      <a href="/" class="mobile-header__name">Francesco Giacomi</a>
      <button class="mobile-header__toggle" id="menu-toggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </header>

    <!-- Main content -->
    <main class="main">

      <!-- Selected Moments: single photo viewer -->
      <section class="viewer" id="section-selected">
        <div class="viewer__top">
          <div class="viewer__nav">
            <button class="viewer__btn" id="btn-prev">Previous</button>
            <span class="viewer__sep">/</span>
            <button class="viewer__btn" id="btn-next">Next</button>
            <span class="viewer__count" id="viewer-count">(1 of {selectedPhotos.length})</span>
          </div>
          <button class="viewer__grid-toggle" id="btn-grid" aria-label="Grid view">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor">
              <rect x="0" y="0" width="4" height="4" rx="0.5"/>
              <rect x="7" y="0" width="4" height="4" rx="0.5"/>
              <rect x="14" y="0" width="4" height="4" rx="0.5"/>
              <rect x="0" y="7" width="4" height="4" rx="0.5"/>
              <rect x="7" y="7" width="4" height="4" rx="0.5"/>
              <rect x="14" y="7" width="4" height="4" rx="0.5"/>
              <rect x="0" y="14" width="4" height="4" rx="0.5"/>
              <rect x="7" y="14" width="4" height="4" rx="0.5"/>
              <rect x="14" y="14" width="4" height="4" rx="0.5"/>
            </svg>
          </button>
        </div>

        <div class="viewer__stage" id="viewer-stage">
          {selectedPhotos.map((photo, i) => {
            const resolved = resolveImage(photo.src);
            return (
              <div class={`viewer__slide ${i === 0 ? 'is-active' : ''}`} data-index={i}>
                <Image
                  src={resolved}
                  alt={photo.caption}
                  widths={[800, 1200, 1800]}
                  sizes="(max-width: 768px) 100vw, 70vw"
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              </div>
            );
          })}
        </div>

        <p class="viewer__caption" id="viewer-caption">{selectedPhotos[0].caption}</p>

        <!-- Grid view -->
        <div class="grid-view" id="grid-view">
          {selectedPhotos.map((photo, i) => {
            const resolved = resolveImage(photo.src);
            return (
              <button class="grid-view__item" data-goto={i}>
                <Image
                  src={resolved}
                  alt={photo.caption}
                  widths={[200, 350]}
                  sizes="20vw"
                  loading="lazy"
                />
              </button>
            );
          })}
        </div>
      </section>

      <!-- Bio section -->
      <section class="bio-section" id="section-bio" style="display:none;">
        <div class="bio-section__content">
          <div class="bio-section__text">
            <p>L'India è stato il primo grande viaggio che ho intrapreso, e da lì è nato, quasi senza accorgermene, un piccolo progetto fotografico.</p>
            <p>Sono partito con una Fuji X-T3 e un 35 mm, senza aspettative e senza una direzione precisa. La fotografia mi ha sempre accompagnato, ma allora non ero ancora in grado di comprendere davvero cosa avrei potuto vedere attraverso una lente.</p>
            <p>Ogni viaggio è diventato un capitolo — frammenti di umanità incontrata lungo il cammino. Perché, a volte, vedere non significa capire, ma semplicemente essere presenti.</p>
          </div>
          <div class="bio-section__image">
            <Image
              src={import('../assets/images/about-portrait.jpg')}
              alt="Francesco Giacomi"
              widths={[400, 600]}
              sizes="(max-width: 768px) 100vw, 50vw"
              loading="lazy"
            />
          </div>
        </div>
      </section>

    </main>

    <script is:inline define:vars={{ captions: selectedPhotos.map(p => p.caption), total: selectedPhotos.length }}>
      let current = 0;
      let gridOpen = false;

      const slides = document.querySelectorAll('.viewer__slide');
      const captionEl = document.getElementById('viewer-caption');
      const countEl = document.getElementById('viewer-count');
      const gridView = document.getElementById('grid-view');
      const viewerStage = document.getElementById('viewer-stage');
      const viewerTop = document.querySelector('.viewer__top');

      function goTo(index) {
        slides.forEach(s => s.classList.remove('is-active'));
        slides[index].classList.add('is-active');
        captionEl.textContent = captions[index];
        countEl.textContent = `(${index + 1} of ${total})`;
        current = index;
      }

      document.getElementById('btn-prev').addEventListener('click', () => {
        goTo(current > 0 ? current - 1 : total - 1);
      });

      document.getElementById('btn-next').addEventListener('click', () => {
        goTo(current < total - 1 ? current + 1 : 0);
      });

      // Keyboard navigation
      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') goTo(current > 0 ? current - 1 : total - 1);
        if (e.key === 'ArrowRight') goTo(current < total - 1 ? current + 1 : 0);
        if (e.key === 'Escape' && gridOpen) toggleGrid();
      });

      // Grid toggle
      function toggleGrid() {
        gridOpen = !gridOpen;
        gridView.classList.toggle('is-open', gridOpen);
        viewerStage.style.display = gridOpen ? 'none' : '';
        captionEl.style.display = gridOpen ? 'none' : '';
        viewerTop.querySelector('.viewer__nav').style.display = gridOpen ? 'none' : '';
      }

      document.getElementById('btn-grid').addEventListener('click', toggleGrid);

      gridView.querySelectorAll('.grid-view__item').forEach(btn => {
        btn.addEventListener('click', () => {
          goTo(parseInt(btn.dataset.goto));
          if (gridOpen) toggleGrid();
        });
      });

      // Sidebar nav - Projects toggle
      document.querySelector('[data-toggle="projects"]').addEventListener('click', () => {
        document.getElementById('nav-projects').classList.toggle('is-open');
        const arrow = document.querySelector('[data-toggle="projects"] .nav-arrow');
        arrow.textContent = document.getElementById('nav-projects').classList.contains('is-open') ? '▾' : '▸';
      });

      // Sidebar nav - section switching
      document.querySelectorAll('[data-section]').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const section = link.dataset.section;
          document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('is-active'));
          link.classList.add('is-active');

          document.getElementById('section-selected').style.display = section === 'selected' ? '' : 'none';
          document.getElementById('section-bio').style.display = section === 'bio' ? '' : 'none';
        });
      });

      // Mobile menu
      const sidebar = document.getElementById('sidebar');
      const toggle = document.getElementById('menu-toggle');
      toggle.addEventListener('click', () => {
        sidebar.classList.toggle('is-open');
        toggle.classList.toggle('is-open');
        document.body.style.overflow = sidebar.classList.contains('is-open') ? 'hidden' : '';
      });

      sidebar.querySelectorAll('a[data-section], .nav-sub__link').forEach(link => {
        link.addEventListener('click', () => {
          sidebar.classList.remove('is-open');
          toggle.classList.remove('is-open');
          document.body.style.overflow = '';
        });
      });

      // Lazy image fade-in
      document.querySelectorAll('img[loading="lazy"]').forEach((img) => {
        if (img.complete) {
          img.classList.add('is-loaded');
        } else {
          img.addEventListener('load', () => img.classList.add('is-loaded'));
        }
      });
    </script>

    <style is:global>
      body {
        overflow-x: hidden;
        margin: 0;
        background: var(--color-bg);
      }

      /* Sidebar */
      .sidebar {
        position: fixed;
        top: 0;
        left: 0;
        width: 200px;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 32px 28px;
        z-index: 100;
        background: var(--color-bg);
      }

      .sidebar__name {
        display: flex;
        flex-direction: column;
        font-size: 1.375rem;
        font-weight: 400;
        line-height: 1.2;
        letter-spacing: -0.01em;
        color: var(--color-text);
        margin-bottom: 32px;
      }

      .sidebar__nav {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .nav-link {
        font-size: 0.8125rem;
        font-weight: 400;
        color: var(--color-text-muted);
        padding: 4px 0;
        transition: color var(--transition);
        text-align: left;
        display: block;
        width: fit-content;
      }

      .nav-link:hover,
      .nav-link.is-active {
        color: var(--color-text);
      }

      .nav-link--parent {
        display: flex;
        align-items: center;
        gap: 4px;
      }

      .nav-arrow {
        font-size: 0.625rem;
      }

      .nav-sub {
        display: none;
        flex-direction: column;
        padding-left: 12px;
        gap: 1px;
      }

      .nav-sub.is-open {
        display: flex;
      }

      .nav-sub__link {
        font-size: 0.75rem;
        color: var(--color-text-muted);
        padding: 3px 0;
        transition: color var(--transition);
      }

      .nav-sub__link:hover {
        color: var(--color-text);
      }

      .sidebar__bottom {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .sidebar__social {
        display: flex;
        gap: 12px;
      }

      .sidebar__social a {
        color: var(--color-text-muted);
        transition: color var(--transition);
      }

      .sidebar__social a:hover {
        color: var(--color-text);
      }

      .sidebar__copy {
        font-size: 0.6875rem;
        color: var(--color-text-muted);
        letter-spacing: 0.02em;
      }

      /* Mobile header */
      .mobile-header {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 110;
        padding: 16px 20px;
        background: var(--color-bg);
        align-items: center;
        justify-content: space-between;
      }

      .mobile-header__name {
        font-size: 1rem;
        font-weight: 400;
        color: var(--color-text);
      }

      .mobile-header__toggle {
        display: flex;
        flex-direction: column;
        gap: 5px;
        padding: 4px;
      }

      .mobile-header__toggle span {
        display: block;
        width: 22px;
        height: 1.5px;
        background: var(--color-text);
        transition: transform 0.3s ease, opacity 0.3s ease;
      }

      .mobile-header__toggle.is-open span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }

      .mobile-header__toggle.is-open span:nth-child(2) {
        opacity: 0;
      }

      .mobile-header__toggle.is-open span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }

      /* Main */
      .main {
        margin-left: 200px;
        min-height: 100vh;
      }

      /* Viewer */
      .viewer {
        padding: 32px 40px 40px;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .viewer__top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
      }

      .viewer__nav {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .viewer__btn {
        font-size: 0.8125rem;
        font-weight: 400;
        color: var(--color-text-muted);
        text-decoration: underline;
        text-underline-offset: 3px;
        transition: color var(--transition);
        padding: 0;
      }

      .viewer__btn:hover {
        color: var(--color-text);
      }

      .viewer__sep {
        font-size: 0.8125rem;
        color: var(--color-text-muted);
      }

      .viewer__count {
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        margin-left: 8px;
      }

      .viewer__grid-toggle {
        color: var(--color-text-muted);
        transition: color var(--transition);
        padding: 4px;
      }

      .viewer__grid-toggle:hover {
        color: var(--color-text);
      }

      .viewer__stage {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .viewer__slide {
        display: none;
        width: 100%;
        max-width: 900px;
      }

      .viewer__slide.is-active {
        display: block;
      }

      .viewer__slide img {
        width: 100%;
        height: auto;
        max-height: 75vh;
        object-fit: contain;
      }

      .viewer__caption {
        margin-top: 20px;
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        letter-spacing: 0.02em;
      }

      /* Grid view */
      .grid-view {
        display: none;
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
        padding: 0;
      }

      .grid-view.is-open {
        display: grid;
        flex: 1;
      }

      .grid-view__item {
        aspect-ratio: 3 / 2;
        overflow: hidden;
        padding: 0;
        background: var(--color-bg-raised);
      }

      .grid-view__item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
      }

      .grid-view__item:hover img {
        transform: scale(1.03);
      }

      /* Bio section */
      .bio-section {
        padding: 32px 40px 80px;
        min-height: 100vh;
      }

      .bio-section__content {
        display: flex;
        flex-direction: column;
        gap: 40px;
        max-width: 800px;
      }

      @media (min-width: 900px) {
        .bio-section__content {
          flex-direction: row;
          align-items: flex-start;
        }
      }

      .bio-section__text {
        flex: 1;
      }

      .bio-section__text p {
        font-size: 0.9375rem;
        line-height: 1.8;
        color: var(--color-text-muted);
        margin-bottom: 1rem;
      }

      .bio-section__text p:last-child {
        margin-bottom: 0;
      }

      .bio-section__image {
        flex-shrink: 0;
        width: 280px;
      }

      .bio-section__image img {
        width: 100%;
        height: auto;
      }

      /* Mobile responsive */
      @media (max-width: 768px) {
        .sidebar {
          transform: translateX(-100%);
          transition: transform 0.35s ease;
          width: 260px;
          padding-top: 72px;
        }

        .sidebar.is-open {
          transform: translateX(0);
        }

        .mobile-header {
          display: flex;
        }

        .main {
          margin-left: 0;
          padding-top: 56px;
        }

        .viewer {
          padding: 20px 16px 32px;
        }

        .viewer__slide img {
          max-height: 60vh;
        }

        .grid-view {
          grid-template-columns: repeat(2, 1fr);
        }

        .bio-section {
          padding: 20px 16px 60px;
        }

        .bio-section__image {
          width: 100%;
        }
      }
    </style>
  </body>
</html>
