---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero.jpg';
---

<BaseLayout
  title="Francesco Giacomi | Photography"
  description="Landscape and travel photography by Francesco Giacomi."
  transparentHeader={true}
>
  <section class="hero">
    <div class="hero__image">
      <Image
        src={heroImage}
        alt="Landscape photography by Francesco Giacomi"
        widths={[800, 1200, 1800, 2400]}
        sizes="100vw"
        loading="eager"
      />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title">Francesco Giacomi</h1>
      <p class="hero__subtitle">Landscape & Travel Photography</p>
    </div>
    <a href="#intro" class="hero__scroll" aria-label="Scroll down">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </a>
  </section>

  <section class="intro" id="intro">
    <div class="container">
      <p>Photographs born from summer travels. Stories told through landscapes, light, and the quiet moments in between.</p>
      <a href="/collections" class="intro__link">View Collections &rarr;</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
  }

  .hero__image {
    position: absolute;
    inset: 0;
  }

  .hero__image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    text-align: center;
    color: #fff;
    padding: var(--spacing-lg);
  }

  .hero__title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero__subtitle {
    margin-top: var(--spacing-md);
    font-size: clamp(0.875rem, 2vw, 1.125rem);
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  .hero__scroll {
    position: absolute;
    bottom: var(--spacing-xl);
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    color: #fff;
    opacity: 0.7;
    animation: bounce 2s ease infinite;
    transition: opacity var(--transition);
  }

  .hero__scroll:hover {
    opacity: 1;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
    40% { transform: translateX(-50%) translateY(-8px); }
    60% { transform: translateX(-50%) translateY(-4px); }
  }

  .intro {
    padding: var(--spacing-2xl) 0;
    text-align: center;
  }

  .intro p {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 700px;
    margin: 0 auto;
  }

  .intro__link {
    display: inline-block;
    margin-top: var(--spacing-lg);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-text);
    padding-bottom: 2px;
    transition: opacity var(--transition);
  }

  .intro__link:hover {
    opacity: 0.6;
  }
</style>
