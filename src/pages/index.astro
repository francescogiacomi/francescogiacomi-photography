---
import '@fontsource/geist-sans/400.css';
import '@fontsource/geist-sans/500.css';
import '@fontsource/geist-sans/600.css';
import '@fontsource/geist-sans/700.css';
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const allCollections = await getCollection('collections');
const sorted = allCollections.sort((a, b) => a.data.order - b.data.order);

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/collections/**/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

function resolveImage(src: string): ImageMetadata {
  const key = Object.keys(allImages).find((k) => k.includes(src));
  if (!key) throw new Error(`Image not found: ${src}`);
  return allImages[key].default;
}

const selectedPhotos = [
  { src: 'peru01/_PXP7086.jpg', caption: 'Perù, 2024' },
  { src: 'peru01/_PXP6623.jpg', caption: 'Perù, 2024' },
  { src: 'peru01/_PXP6798.jpg', caption: 'Perù, 2024' },
  { src: 'peru01/_PXP7308.jpg', caption: 'Bolivia, 2024' },
  { src: 'peru01/_PXP7095.jpg', caption: 'Perù, 2024' },
  { src: 'peru01/_PXP7632.jpg', caption: 'Cile, 2024' },
  { src: 'peru01/_PXP7145.jpg', caption: 'Bolivia, 2024' },
  { src: 'peru01/_PXP7360.jpg', caption: 'Cile, 2024' },
  { src: 'peru01/_PXP6437.jpg', caption: 'Perù, 2024' },
  { src: 'peru01/_PXP7159.jpg', caption: 'Perù, 2024' },
  { src: 'peru01/_PXP6768.jpg', caption: 'Perù, 2024' },
  { src: 'peru01/_PXP7866.jpg', caption: 'Perù, 2024' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title="Francesco Giacomi | Photography"
      description="Travel and documentary photography by Francesco Giacomi."
    />
  </head>
  <body>

    <!-- Desktop sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar__top">
        <a href="/" class="sidebar__name">
          <span>Francesco</span>
          <span>Giacomi</span>
        </a>
        <nav class="sidebar__nav">
          <a href="#" class="nav-link is-active" data-section="selected">Selected Moments</a>
          <div class="nav-group">
            <span class="nav-label">Projects</span>
            <div class="nav-sub">
              {sorted.map((entry) => (
                <a href={`/collections/${entry.data.slug}`} class="nav-sub__link">{entry.data.title} ({entry.data.year})</a>
              ))}
            </div>
          </div>
          <a href="#" class="nav-link" data-section="bio">Bio</a>
        </nav>
      </div>
      <div class="sidebar__bottom">
        <div class="sidebar__social">
          <a href="https://www.instagram.com/fncgcm/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.336 3.608 1.311.975.975 1.249 2.242 1.311 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.336 2.633-1.311 3.608-.975.975-2.242 1.249-3.608 1.311-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.336-3.608-1.311-.975-.975-1.249-2.242-1.311-3.608-.058-1.266-.07-1.646-.07-4.85s.012-3.584.07-4.85c.062-1.366.336-2.633 1.311-3.608.975-.975 2.242-1.249 3.608-1.311 1.266-.058 1.646-.07 4.85-.07zm0 1.802c-3.15 0-3.523.012-4.766.069-.93.042-1.518.196-1.943.363-.42.163-.872.42-1.255.803-.383.383-.64.835-.803 1.255-.167.425-.321 1.013-.363 1.943-.057 1.243-.069 1.616-.069 4.766s.012 3.523.069 4.766c.042.93.196 1.518.363 1.943.163.42.42.872.803 1.255.383.383.835.64 1.255.803.425.167 1.013.321 1.943.363 1.243.057 1.616.069 4.766.069s3.523-.012 4.766-.069c.93-.042 1.518-.196 1.943-.363.42-.163.872-.42 1.255-.803.383-.383.64-.835.803-1.255.167-.425.321-1.013.363-1.943.057-1.243.069-1.616.069-4.766s-.012-3.523-.069-4.766c-.042-.93-.196-1.518-.363-1.943-.163-.42-.42-.872-.803-1.255-.383-.383-.835-.64-1.255-.803-.425-.167-1.013-.321-1.943-.363-1.243-.057-1.616-.069-4.766-.069zm0 3.064a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm6.538-3.31a1.2 1.2 0 11-2.4 0 1.2 1.2 0 012.4 0z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/francescogiacomi/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/></svg>
          </a>
        </div>
        <span class="sidebar__copy">&copy; All rights reserved</span>
      </div>
    </aside>

    <!-- Mobile header -->
    <header class="mobile-header" id="mobile-header">
      <a href="/" class="mobile-header__name">
        <span>Francesco</span>
        <span>Giacomi</span>
      </a>
      <button class="mobile-header__toggle" id="menu-toggle" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </header>

    <!-- Mobile menu overlay -->
    <div class="mobile-menu-backdrop" id="menu-backdrop"></div>
    <div class="mobile-menu" id="mobile-menu">
      <div class="mobile-menu__inner">
        <button class="mobile-menu__close" id="menu-close" aria-label="Close">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <nav class="mobile-menu__nav">
          <a href="#" class="mobile-menu__link is-active" data-section="selected">Selected Moments</a>
          <div class="mobile-menu__group">
            <span class="mobile-menu__label">Projects</span>
            {sorted.map((entry) => (
              <a href={`/collections/${entry.data.slug}`} class="mobile-menu__sub">{entry.data.title} ({entry.data.year})</a>
            ))}
          </div>
          <a href="#" class="mobile-menu__link" data-section="bio">Bio</a>
        </nav>
        <div class="mobile-menu__bottom">
          <div class="mobile-menu__social">
            <a href="https://www.instagram.com/fncgcm/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.336 3.608 1.311.975.975 1.249 2.242 1.311 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.336 2.633-1.311 3.608-.975.975-2.242 1.249-3.608 1.311-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.336-3.608-1.311-.975-.975-1.249-2.242-1.311-3.608-.058-1.266-.07-1.646-.07-4.85s.012-3.584.07-4.85c.062-1.366.336-2.633 1.311-3.608.975-.975 2.242-1.249 3.608-1.311 1.266-.058 1.646-.07 4.85-.07zm0 1.802c-3.15 0-3.523.012-4.766.069-.93.042-1.518.196-1.943.363-.42.163-.872.42-1.255.803-.383.383-.64.835-.803 1.255-.167.425-.321 1.013-.363 1.943-.057 1.243-.069 1.616-.069 4.766s.012 3.523.069 4.766c.042.93.196 1.518.363 1.943.163.42.42.872.803 1.255.383.383.835.64 1.255.803.425.167 1.013.321 1.943.363 1.243.057 1.616.069 4.766.069s3.523-.012 4.766-.069c.93-.042 1.518-.196 1.943-.363.42-.163.872-.42 1.255-.803.383-.383.64-.835.803-1.255.167-.425.321-1.013.363-1.943.057-1.243.069-1.616.069-4.766s-.012-3.523-.069-4.766c-.042-.93-.196-1.518-.363-1.943-.163-.42-.42-.872-.803-1.255-.383-.383-.835-.64-1.255-.803-.425-.167-1.013-.321-1.943-.363-1.243-.057-1.616-.069-4.766-.069zm0 3.064a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm6.538-3.31a1.2 1.2 0 11-2.4 0 1.2 1.2 0 012.4 0z"/></svg>
            </a>
            <a href="https://www.linkedin.com/in/francescogiacomi/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/></svg>
            </a>
          </div>
          <span class="mobile-menu__copy">&copy; All rights reserved</span>
        </div>
      </div>
    </div>

    <!-- Main content -->
    <main class="main">

      <!-- Selected Moments -->
      <section class="viewer" id="section-selected">
        <!-- Desktop: top bar with prev/next + grid toggle -->
        <div class="viewer__top">
          <div class="viewer__nav" id="viewer-nav">
            <button class="viewer__btn" id="btn-prev">Previous</button>
            <span class="viewer__sep">/</span>
            <button class="viewer__btn" id="btn-next">Next</button>
            <span class="viewer__count" id="viewer-count">(1 of {selectedPhotos.length})</span>
          </div>
          <button class="viewer__mode-toggle" id="btn-mode" aria-label="Toggle view">
            <svg class="icon-grid" width="18" height="18" viewBox="0 0 18 18" fill="currentColor">
              <rect x="0" y="0" width="4" height="4" rx="0.5"/><rect x="7" y="0" width="4" height="4" rx="0.5"/><rect x="14" y="0" width="4" height="4" rx="0.5"/>
              <rect x="0" y="7" width="4" height="4" rx="0.5"/><rect x="7" y="7" width="4" height="4" rx="0.5"/><rect x="14" y="7" width="4" height="4" rx="0.5"/>
              <rect x="0" y="14" width="4" height="4" rx="0.5"/><rect x="7" y="14" width="4" height="4" rx="0.5"/><rect x="14" y="14" width="4" height="4" rx="0.5"/>
            </svg>
            <svg class="icon-single" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" style="display:none;">
              <rect x="1" y="1" width="16" height="12" rx="1"/><line x1="1" y1="16" x2="12" y2="16"/>
            </svg>
          </button>
        </div>

        <!-- Desktop: single photo viewer -->
        <div class="viewer__stage" id="viewer-stage">
          {selectedPhotos.map((photo, i) => {
            const resolved = resolveImage(photo.src);
            return (
              <div class={`viewer__slide ${i === 0 ? 'is-active' : ''}`} data-index={i}>
                <Image
                  src={resolved}
                  alt={photo.caption}
                  widths={[800, 1200, 1800]}
                  sizes="(max-width: 768px) 100vw, 70vw"
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              </div>
            );
          })}
        </div>
        <p class="viewer__caption" id="viewer-caption">{selectedPhotos[0].caption}</p>

        <!-- Desktop: grid view -->
        <div class="grid-view" id="grid-view">
          {selectedPhotos.map((photo, i) => {
            const resolved = resolveImage(photo.src);
            return (
              <button class="grid-view__item" data-goto={i}>
                <Image
                  src={resolved}
                  alt={photo.caption}
                  widths={[200, 350]}
                  sizes="20vw"
                  loading="lazy"
                />
              </button>
            );
          })}
        </div>

        <!-- Mobile: scrolling feed -->
        <div class="mobile-feed" id="mobile-feed">
          {selectedPhotos.map((photo) => {
            const resolved = resolveImage(photo.src);
            return (
              <figure class="mobile-feed__item">
                <Image
                  src={resolved}
                  alt={photo.caption}
                  widths={[600, 900, 1200]}
                  sizes="100vw"
                  loading="lazy"
                />
                <figcaption>{photo.caption}</figcaption>
              </figure>
            );
          })}
        </div>
      </section>

      <!-- Bio section -->
      <section class="bio-section" id="section-bio" style="display:none;">
        <div class="bio-section__content">
          <div class="bio-section__text">
            <p>L'India è stato il primo grande viaggio che ho intrapreso, e da lì è nato, quasi senza accorgermene, un piccolo progetto fotografico.</p>
            <p>Sono partito con una Fuji X-T3 e un 35 mm, senza aspettative e senza una direzione precisa. La fotografia mi ha sempre accompagnato, ma allora non ero ancora in grado di comprendere davvero cosa avrei potuto vedere attraverso una lente.</p>
            <p>Ogni viaggio è diventato un capitolo — frammenti di umanità incontrata lungo il cammino. Perché, a volte, vedere non significa capire, ma semplicemente essere presenti.</p>
          </div>
          <div class="bio-section__image">
            <Image
              src={import('../assets/images/about-portrait.jpg')}
              alt="Francesco Giacomi"
              widths={[400, 600]}
              sizes="(max-width: 768px) 100vw, 50vw"
              loading="lazy"
            />
          </div>
        </div>
      </section>

    </main>

    <script is:inline define:vars={{ captions: selectedPhotos.map(p => p.caption), total: selectedPhotos.length }}>
      let current = 0;
      let gridOpen = false;

      const slides = document.querySelectorAll('.viewer__slide');
      const captionEl = document.getElementById('viewer-caption');
      const countEl = document.getElementById('viewer-count');
      const gridView = document.getElementById('grid-view');
      const viewerStage = document.getElementById('viewer-stage');
      const viewerNav = document.getElementById('viewer-nav');
      const iconGrid = document.querySelector('.icon-grid');
      const iconSingle = document.querySelector('.icon-single');

      function goTo(index) {
        slides.forEach(s => s.classList.remove('is-active'));
        slides[index].classList.add('is-active');
        captionEl.textContent = captions[index];
        countEl.textContent = '(' + (index + 1) + ' of ' + total + ')';
        current = index;
      }

      document.getElementById('btn-prev').addEventListener('click', () => {
        goTo(current > 0 ? current - 1 : total - 1);
      });

      document.getElementById('btn-next').addEventListener('click', () => {
        goTo(current < total - 1 ? current + 1 : 0);
      });

      // Click the photo to advance to the next one
      viewerStage.addEventListener('click', () => {
        if (!gridOpen) goTo(current < total - 1 ? current + 1 : 0);
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') goTo(current > 0 ? current - 1 : total - 1);
        if (e.key === 'ArrowRight') goTo(current < total - 1 ? current + 1 : 0);
        if (e.key === 'Escape' && gridOpen) toggleGrid();
      });

      function toggleGrid() {
        gridOpen = !gridOpen;
        gridView.classList.toggle('is-open', gridOpen);
        viewerStage.style.display = gridOpen ? 'none' : '';
        captionEl.style.display = gridOpen ? 'none' : '';
        viewerNav.style.display = gridOpen ? 'none' : '';
        iconGrid.style.display = gridOpen ? 'none' : '';
        iconSingle.style.display = gridOpen ? '' : 'none';
      }

      document.getElementById('btn-mode').addEventListener('click', toggleGrid);

      gridView.querySelectorAll('.grid-view__item').forEach(btn => {
        btn.addEventListener('click', () => {
          goTo(parseInt(btn.dataset.goto));
          if (gridOpen) toggleGrid();
        });
      });

      // Sidebar nav
      document.querySelectorAll('[data-section]').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const section = link.dataset.section;

          // Desktop sidebar
          document.querySelectorAll('.sidebar .nav-link').forEach(l => l.classList.remove('is-active'));
          const sidebarLink = document.querySelector('.sidebar [data-section="' + section + '"]');
          if (sidebarLink) sidebarLink.classList.add('is-active');

          // Mobile menu
          document.querySelectorAll('.mobile-menu__link').forEach(l => l.classList.remove('is-active'));
          const mobileLink = document.querySelector('.mobile-menu [data-section="' + section + '"]');
          if (mobileLink) mobileLink.classList.add('is-active');

          document.getElementById('section-selected').style.display = section === 'selected' ? '' : 'none';
          document.getElementById('section-bio').style.display = section === 'bio' ? '' : 'none';

          // Close mobile menu
          closeMenu();
        });
      });

      // Mobile menu
      const mobileMenu = document.getElementById('mobile-menu');
      const menuBackdrop = document.getElementById('menu-backdrop');

      function openMenu() {
        mobileMenu.classList.add('is-open');
        menuBackdrop.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        mobileMenu.classList.remove('is-open');
        menuBackdrop.classList.remove('is-open');
        document.body.style.overflow = '';
      }

      document.getElementById('menu-toggle').addEventListener('click', openMenu);
      document.getElementById('menu-close').addEventListener('click', closeMenu);
      menuBackdrop.addEventListener('click', closeMenu);

      // Lazy image fade-in
      document.querySelectorAll('img[loading="lazy"]').forEach((img) => {
        if (img.complete) {
          img.classList.add('is-loaded');
        } else {
          img.addEventListener('load', () => img.classList.add('is-loaded'));
        }
      });
    </script>

    <style is:global>
      body {
        overflow-x: hidden;
        margin: 0;
      }

      /* ===== SIDEBAR (desktop) ===== */
      .sidebar {
        position: fixed;
        top: 0;
        left: 0;
        width: 200px;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 32px 28px;
        z-index: 100;
      }

      .sidebar__name {
        display: flex;
        flex-direction: column;
        font-size: 1.375rem;
        font-weight: 400;
        line-height: 1.2;
        color: var(--color-text);
        margin-bottom: 40px;
      }

      .sidebar__nav {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .nav-link {
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        padding: 3px 0;
        transition: color var(--transition);
        text-align: left;
        display: block;
      }

      .nav-link:hover { color: var(--color-text); }
      .nav-link.is-active { color: var(--color-accent); }

      .nav-label {
        display: block;
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--color-text);
        padding: 3px 0;
        margin-top: 16px;
      }

      .nav-sub {
        display: flex;
        flex-direction: column;
        gap: 2px;
        margin-top: 4px;
      }

      .nav-sub__link {
        font-size: 0.75rem;
        color: var(--color-text-muted);
        padding: 2px 0;
        transition: color var(--transition);
      }

      .nav-sub__link:hover { color: var(--color-text); }

      .sidebar__bottom {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .sidebar__social {
        display: flex;
        gap: 14px;
      }

      .sidebar__social a {
        color: var(--color-text-muted);
        transition: opacity var(--transition);
      }

      .sidebar__social a:hover { opacity: 0.6; }

      .sidebar__copy {
        font-size: 0.6875rem;
        color: var(--color-text-muted);
      }

      /* ===== MOBILE HEADER ===== */
      .mobile-header {
        display: none;
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 110;
        padding: 20px;
        align-items: flex-start;
        justify-content: space-between;
      }

      .mobile-header__name {
        display: flex;
        flex-direction: column;
        font-size: 1.25rem;
        font-weight: 400;
        line-height: 1.15;
        color: var(--color-text);
      }

      .mobile-header__toggle {
        color: var(--color-text);
        padding: 4px;
        margin-top: 2px;
      }

      /* ===== MOBILE MENU OVERLAY ===== */
      .mobile-menu-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 190;
        background: rgba(0, 0, 0, 0.35);
        opacity: 0;
        transition: opacity 0.35s ease;
        pointer-events: none;
      }

      .mobile-menu-backdrop.is-open {
        opacity: 1;
        pointer-events: auto;
      }

      .mobile-menu {
        position: fixed;
        top: 0; right: 0;
        width: 55%;
        min-width: 260px;
        height: 100vh;
        z-index: 200;
        background: var(--color-bg);
        box-shadow: -16px 0 40px rgba(0, 0, 0, 0.18);
        transform: translateX(100%);
        transition: transform 0.35s ease;
        overflow-y: auto;
      }

      .mobile-menu.is-open {
        transform: translateX(0);
      }

      .mobile-menu__inner {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 100vh;
        padding: 20px 24px 32px;
      }

      .mobile-menu__close {
        align-self: flex-end;
        color: var(--color-accent);
        padding: 4px;
        margin-bottom: 24px;
      }

      .mobile-menu__nav {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .mobile-menu__link {
        font-size: 0.9375rem;
        color: var(--color-text-muted);
        padding: 4px 0;
      }

      .mobile-menu__link.is-active {
        color: var(--color-accent);
      }

      .mobile-menu__label {
        display: block;
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--color-text);
        padding: 4px 0;
        margin-top: 20px;
      }

      .mobile-menu__sub {
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        padding: 3px 0;
        display: block;
        transition: color var(--transition);
      }

      .mobile-menu__sub:hover { color: var(--color-text); }

      .mobile-menu__bottom {
        margin-top: auto;
        padding-top: 40px;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .mobile-menu__social {
        display: flex;
        gap: 14px;
      }

      .mobile-menu__social a {
        color: var(--color-text-muted);
      }

      .mobile-menu__copy {
        font-size: 0.6875rem;
        color: var(--color-text-muted);
      }

      /* ===== MAIN ===== */
      .main {
        margin-left: 200px;
        min-height: 100vh;
      }

      /* ===== VIEWER (desktop single photo) ===== */
      .viewer {
        padding: 40px 64px 56px;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .viewer__top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
      }

      .viewer__nav {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .viewer__btn {
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        text-decoration: underline;
        text-underline-offset: 3px;
        transition: color var(--transition);
      }

      .viewer__btn:hover { color: var(--color-text); }

      .viewer__sep,
      .viewer__count {
        font-size: 0.8125rem;
        color: var(--color-text-muted);
      }

      .viewer__count { margin-left: 8px; }

      .viewer__mode-toggle {
        color: var(--color-text-muted);
        transition: color var(--transition);
        padding: 4px;
        margin-left: auto;
      }

      .viewer__mode-toggle:hover { color: var(--color-text); }

      .viewer__stage {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .viewer__slide {
        display: none;
        width: 100%;
        max-width: 900px;
      }

      .viewer__slide.is-active { display: block; }

      .viewer__slide img {
        width: 100%;
        height: auto;
        max-height: 75vh;
        object-fit: contain;
      }

      .viewer__caption {
        margin-top: 20px;
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        font-style: italic;
      }

      /* ===== GRID VIEW ===== */
      .grid-view {
        display: none;
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
      }

      .grid-view.is-open {
        display: grid;
        flex: 1;
        align-content: start;
      }

      .grid-view__item {
        aspect-ratio: 3 / 2;
        overflow: hidden;
        padding: 0;
        background: var(--color-bg-raised);
      }

      .grid-view__item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
      }

      .grid-view__item:hover img { transform: scale(1.03); }

      /* ===== MOBILE FEED (scroll) ===== */
      .mobile-feed {
        display: none;
      }

      .mobile-feed__item {
        margin-bottom: 8px;
      }

      .mobile-feed__item img {
        width: 100%;
        height: auto;
      }

      .mobile-feed__item figcaption {
        padding: 12px 0 24px;
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        font-style: italic;
      }

      /* ===== BIO ===== */
      .bio-section {
        padding: 32px 40px 80px;
      }

      .bio-section__content {
        display: flex;
        flex-direction: column;
        gap: 40px;
        max-width: 800px;
      }

      @media (min-width: 900px) {
        .bio-section__content {
          flex-direction: row;
          align-items: flex-start;
        }
      }

      .bio-section__text { flex: 1; }

      .bio-section__text p {
        font-size: 0.9375rem;
        line-height: 1.8;
        color: var(--color-text-muted);
        margin-bottom: 1rem;
      }

      .bio-section__text p:last-child { margin-bottom: 0; }

      .bio-section__image {
        flex-shrink: 0;
        width: 280px;
      }

      .bio-section__image img {
        width: 100%;
        height: auto;
      }

      /* ===== MOBILE RESPONSIVE ===== */
      @media (max-width: 768px) {
        .sidebar { display: none; }

        .mobile-header { display: flex; }

        .mobile-menu-backdrop { display: block; }

        .main {
          margin-left: 0;
          padding-top: 80px;
        }

        .viewer {
          padding: 0;
          min-height: auto;
        }

        .viewer__top { display: none; }
        .viewer__stage { display: none !important; }
        .viewer__caption { display: none !important; }
        .grid-view { display: none !important; }

        .mobile-feed {
          display: block;
          padding: 0 20px;
        }

        .bio-section {
          padding: 20px 20px 60px;
        }

        .bio-section__image {
          width: 100%;
        }
      }
    </style>
  </body>
</html>
