---
import GalleryLayout from '../layouts/GalleryLayout.astro';
import { Image } from 'astro:assets';
import portrait from '../assets/images/about-portrait.jpg';
---

<GalleryLayout
  title="Bio | Francesco Giacomi"
  description="About Francesco Giacomi — travel and documentary photographer."
  activeNav="bio"
>
  <section class="bio">
    <div class="bio__inner">
      <div class="bio__text">
        <p>I'm Francesco — not a professional photographer, just someone who has carried a camera on every trip for as long as I can remember.</p>
        <p>Photography started as a way to hold on to moments from travels. Over the years it became something more: a reason to wake up before dawn, to stay out in the cold, to notice the way light falls on a face or a landscape.</p>
        <p>This site is a collection of those moments — organized by trip, told the way I remember them. The photos are honest: no heavy post-processing, no tricks. Just the places and people as I found them, with whatever light was there.</p>
        <p>If any of these photographs resonate with you, I'd love to hear about it.</p>
      </div>
      <div class="bio__image">
        <Image
          src={portrait}
          alt="Francesco Giacomi"
          widths={[400, 600]}
          sizes="(max-width: 768px) 100vw, 320px"
          loading="eager"
        />
      </div>
    </div>
  </section>
</GalleryLayout>

<style>
  .bio {
    padding: 48px 72px 80px;
    min-height: 100vh;
  }

  .bio__inner {
    display: flex;
    flex-direction: column;
    gap: 40px;
    max-width: 860px;
  }

  @media (min-width: 900px) {
    .bio__inner {
      flex-direction: row-reverse;
      align-items: flex-start;
      gap: 56px;
    }
  }

  .bio__text { flex: 1; }

  .bio__text p {
    font-size: 0.9375rem;
    line-height: 1.85;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .bio__text p:last-child { margin-bottom: 0; }

  .bio__image {
    flex-shrink: 0;
    width: 320px;
    max-width: 100%;
  }

  .bio__image :global(img) {
    width: 100%;
    height: auto;
  }

  @media (max-width: 768px) {
    .bio {
      padding: 20px 20px 60px;
    }
    .bio__image { width: 100%; }
  }
</style>
